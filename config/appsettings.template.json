{
  // PerplexityXPC application settings template.
  // This file is copied to %LOCALAPPDATA%\PerplexityXPC\appsettings.json during installation.
  // JSON with comments (JSONC) is supported — use // for single-line and /* */ for block comments.
  "PerplexityXPC": {
    // Base URL for the Perplexity API.
    "ApiEndpoint": "https://api.perplexity.ai",

    // Named Pipe server name — used for IPC between the tray app, context menu handler,
    // and the broker service. Must match across all components.
    "PipeServerName": "PerplexityXPCPipe",

    // HTTP port for the local REST API.
    // Access via http://localhost:47777/v1/query
    // This port is blocked from external access by the installer firewall rule.
    "HttpPort": 47777,

    // Logging level: Trace | Debug | Information | Warning | Error | Critical | None
    "LogLevel": "Information",

    // Directory where log files are written. Defaults to %LOCALAPPDATA%\PerplexityXPC\logs
    // The installer will substitute this with the actual path.
    "LogDirectory": "",

    // Maximum file size (in KB) that the context menu handler will read in full.
    // Files larger than this are truncated to the first N characters.
    "MaxFileSizeKB": 10240,

    // Default Perplexity model to use for queries.
    // See: https://docs.perplexity.ai/guides/model-cards
    "DefaultModel": "llama-3.1-sonar-large-128k-online",

    // Request timeout in seconds for API calls.
    "ApiTimeoutSec": 60,

    // Maximum number of tokens to request per response.
    "MaxTokens": 2048
  },

  "Mcp": {
    // Path to the MCP servers configuration file.
    // Leave empty to use the default: %LOCALAPPDATA%\PerplexityXPC\mcp-servers.json
    "ConfigFile": "",

    // Automatically restart crashed MCP server processes.
    "AutoRestart": true,

    // Seconds to wait for an MCP server to respond before timing out.
    "TimeoutSec": 30,

    // Maximum number of MCP servers that can run concurrently.
    "MaxConcurrentServers": 5
  },

  "Logging": {
    "LogLevel": {
      "Default":                   "Information",
      "Microsoft":                 "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
