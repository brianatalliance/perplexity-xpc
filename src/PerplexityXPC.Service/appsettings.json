{
  // ============================================================
  // PerplexityXPC Service — Default Configuration
  //
  // Environment variable overrides use the PERPLEXITYXPC_ prefix.
  // Example: PERPLEXITYXPC_PORT=47777
  //
  // The Perplexity API key can also be provided via:
  //   - Environment variable: PERPLEXITY_API_KEY
  //   - This file: PerplexityXPC.ApiKey (not recommended for production)
  // ============================================================

  "PerplexityXPC": {
    // ----------------------------------------------------------
    // API Authentication
    // ----------------------------------------------------------

    // Your Perplexity Sonar API key.
    // Get one at https://www.perplexity.ai/settings/api
    // IMPORTANT: Prefer setting PERPLEXITY_API_KEY as an environment variable
    // rather than storing the key in this file.
    "ApiKey": "",

    // ----------------------------------------------------------
    // Network
    // ----------------------------------------------------------

    // TCP port for the HTTP/WebSocket listener.
    // Bound to 127.0.0.1 only — no external access.
    "Port": 47777,

    // Base URL for the Perplexity Sonar API.
    // Change only if routing through a local proxy for testing.
    "PerplexityApiBaseUrl": "https://api.perplexity.ai",

    // HTTP request timeout in seconds for Perplexity API calls.
    // For sonar-deep-research, consider increasing to 300+.
    "ApiTimeoutSeconds": 120,

    // ----------------------------------------------------------
    // Named Pipe
    // ----------------------------------------------------------

    // Named pipe identifier. Full path: \\.\pipe\{PipeName}
    // Must match what the tray app and context menu extension expect.
    "PipeName": "PerplexityXPC",

    // ----------------------------------------------------------
    // Logging
    // ----------------------------------------------------------

    // Minimum log level: Verbose | Debug | Information | Warning | Error | Fatal
    "LogLevel": "Information",

    // Log file directory. Logs rotate daily and are kept for 14 days.
    // Leave empty to use the default: %LOCALAPPDATA%\PerplexityXPC\logs\
    "LogDirectory": "",

    // ----------------------------------------------------------
    // MCP (Model Context Protocol) Servers
    // ----------------------------------------------------------

    // Path to the JSON file that defines MCP server configurations.
    // Default: %LOCALAPPDATA%\PerplexityXPC\mcp-servers.json
    // Set to an empty string to use the default path.
    "McpServersPath": "",

    // Whether to start all auto_start=true MCP servers when the Windows Service starts.
    "AutoStartMcpServers": true,

    // Maximum restart attempts for a crashed MCP server within McpRestartWindowSeconds.
    // If exceeded, the server enters Error state and requires a manual restart.
    "McpMaxRestartAttempts": 3,

    // Time window in seconds for counting MCP restart attempts.
    "McpRestartWindowSeconds": 60,

    // ----------------------------------------------------------
    // Retry Policy
    // ----------------------------------------------------------

    // Maximum retries for Perplexity API calls that fail with HTTP 429 or 503.
    "MaxRetries": 3,

    // Initial retry delay in milliseconds. Subsequent retries use exponential backoff.
    // Retry delays: 1s, 2s, 4s (with MaxRetries=3 and RetryDelayMs=1000)
    "RetryDelayMs": 1000,

    // ----------------------------------------------------------
    // Security
    // ----------------------------------------------------------

    // Whether to add a Windows Firewall inbound block rule for the Port on startup.
    // Requires the service to run as LocalSystem or an account with firewall permissions.
    // Kestrel's loopback binding (127.0.0.1) already prevents external access;
    // this adds a belt-and-suspenders layer.
    "AddFirewallRule": true
  },

  // ----------------------------------------------------------
  // ASP.NET Core / Kestrel logging overrides
  // ----------------------------------------------------------
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Hosting": "Warning",
      "Microsoft.AspNetCore.Routing": "Warning"
    }
  },

  // ----------------------------------------------------------
  // Serilog structured logging (complements the AppConfig.LogLevel setting)
  // These settings are read by the Serilog UseSerilog() call in Program.cs.
  // ----------------------------------------------------------
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },

  // ----------------------------------------------------------
  // AllowedHosts — restrict to localhost only
  // ----------------------------------------------------------
  "AllowedHosts": "localhost;127.0.0.1;::1"
}
